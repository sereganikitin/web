# Сгенерируйте: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# Учётка администратора (создаётся при первом запуске db:init)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-please

# Базовый URL продакшена (для canonical, OG, sitemap)
SITE_URL=https://web.cd-agency.ru

# Код подтверждения для Яндекс.Вебмастера (значение мета-тега yandex-verification).
# Получить: webmaster.yandex.ru → добавить сайт → выбрать "Мета-тег".
# Пример: YANDEX_VERIFICATION=a1b2c3d4e5f6g7h8
YANDEX_VERIFICATION=

# SMTP для email-уведомлений о новых заявках. Если что-то пусто —
# заявка всё равно сохраняется в БД, просто без email.
# Примеры host:port — Яндекс: smtp.yandex.ru:465, Mail.ru: smtp.mail.ru:465,
# Gmail: smtp.gmail.com:465 (нужен App Password).
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
LEAD_NOTIFY_TO=

# Telegram уведомления о новых заявках. Работают независимо от SMTP —
# можно настроить одно, оба или ничего (заявка всё равно сохранится в БД).
#
# Как получить токен и chat_id:
#   1. В Telegram найти @BotFather, /newbot, дать имя — получить TOKEN.
#   2. Написать боту любое сообщение (нужно «активировать» чат с ботом).
#   3. Открыть https://api.telegram.org/bot<TOKEN>/getUpdates — там в
#      message.chat.id будет ваш числовой chat_id (можно отрицательный
#      для группы, начинается с -100 для каналов).
#   4. Если уведомления нужны в группу — добавить бота в неё и сделать
#      админом, иначе он не сможет писать.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
