# Сгенерируйте: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# Учётка администратора (создаётся при первом запуске db:init)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-please

# Базовый URL продакшена (для canonical, OG)
SITE_URL=https://web.cd-agency.ru

# SMTP для email-уведомлений о новых заявках. Если что-то пусто —
# заявка всё равно сохраняется в БД, просто без email.
# Примеры host:port — Яндекс: smtp.yandex.ru:465, Mail.ru: smtp.mail.ru:465,
# Gmail: smtp.gmail.com:465 (нужен App Password).
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
LEAD_NOTIFY_TO=
